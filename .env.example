# JORD Golf Tournament System — Environment Configuration
# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit .env to version control!

# ── Server ──────────────────────────────────────────────────
PORT=3000
APP_URL=http://localhost:3000
NODE_ENV=development

# ── Admin Authentication ────────────────────────────────────
# IMPORTANT: Set a strong, unique password. If not set, a random one will be generated.
# For production, use a cryptographically random string (32+ characters)
ADMIN_PASSWORD=change_me_to_a_strong_password_minimum_16_characters

# Optional: Super admin email for initial account creation
SUPER_ADMIN_EMAIL=admin@example.com

# ── Mapbox (for satellite maps) ──────────────────────────────
# Get a free key at mapbox.com
# Set URL restrictions to your deployment domain
MAPBOX_TOKEN=pk.eyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Anthropic API (optional - for AI-powered zone detection) ───
# Get an API key at console.anthropic.com
# IMPORTANT: Keep this secret and rotate regularly
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Klaviyo (email + SMS marketing) ─────────────────────────
# Set up API key and lists at klaviyo.com
# IMPORTANT: Keep these secret - they control your marketing channels
KLAVIYO_API_KEY=pk_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
KLAVIYO_EMAIL_LIST_ID=XXXXXX
KLAVIYO_SMS_LIST_ID=XXXXXX

# ── Golf Course API (golfcourseapi.com) ─────────────────────
# Free course / scorecard data — get a key at golfcourseapi.com
# Sent via email after signup; used as: Authorization: Key <value>
GOLF_COURSE_API_KEY=YOUR_GOLFCOURSEAPI_KEY_HERE

# ── Stripe (event registration payments + Connect) ──────────
# Test/sandbox keys start with sk_test_ / pk_test_; live keys start with sk_live_ / pk_live_.
# When STRIPE_SECRET_KEY is not set, registrations run in MOCK mode (no charge).
# STRIPE_WEBHOOK_SECRET is the signing secret from the Stripe Dashboard webhook endpoint
# (or `stripe listen` for local dev). Webhook URL: <APP_URL>/api/stripe/webhook.
# STRIPE_PLATFORM_FEE_BPS is the JORD platform fee in basis points (300 = 3.00%).
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY_HERE
STRIPE_PUBLISHABLE_KEY=YOUR_STRIPE_PUBLISHABLE_KEY_HERE
STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SECRET_HERE
STRIPE_PLATFORM_FEE_BPS=300

# ── Deployment Notes ────────────────────────────────────────
# For Railway/Heroku/production:
#   1. Never set secrets in .env files — use platform UI (Settings → Config Vars)
#   2. Always use HTTPS
#   3. Set NODE_ENV=production
#   4. Use a strong, unique ADMIN_PASSWORD
#   5. Rotate API keys quarterly
